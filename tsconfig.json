{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true
  },
  "include": [
    "src/server/**/*",
    "src/services/**/*",
    "src/config/**/*",
    "tests/**/*",
    "vite.*.ts"
  ],
  "exclude": ["src/client"]
}
